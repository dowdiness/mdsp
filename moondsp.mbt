///|
/// Public API facade for the `dowdiness/moondsp` library.
///
/// This file re-exports the library surface provided by `@lib`, which in
/// turn consolidates `@dsp`, `@graph`, and `@voice`. External consumers
/// should prefer `@moondsp.X` over `@moondsp.lib.X`; the `@lib` layer remains
/// as the internal re-export hub that project packages import.
pub using @lib {
  type Adsr,
  type AudioBuffer,
  type Biquad,
  type BiquadMode,
  type Clip,
  type CompiledDsp,
  type CompiledDspHotSwap,
  type CompiledDspTopologyController,
  type CompiledStereoDsp,
  type CompiledStereoDspHotSwap,
  type CompiledStereoDspTopologyController,
  type ControlBinding,
  type ControlBindingBuilder,
  type ControlBindingError,
  type ControlBindingMap,
  type DelayLine,
  type DemoSource,
  type DspContext,
  type DspNode,
  type DspNodeKind,
  type EnvStage,
  type Gain,
  type GraphBuilder,
  type GraphControl,
  type GraphControlKind,
  type GraphParamSlot,
  type GraphTopologyEdit,
  type GraphTopologyInputSlot,
  type GraphValidationError,
  type Mix,
  type Mono,
  type Noise,
  type Oscillator,
  type Pan,
  type ParamSmoother,
  type Stereo,
  type VoiceHandle,
  type VoicePool,
  type VoiceState,
  type Waveform,
  trait ArithSym,
  trait ChannelSpec,
  trait DelaySym,
  trait DspSym,
  trait FilterSym,
  trait GraphControllable,
  trait GraphDebuggable,
  trait NodeEditable,
  trait NodeFoldable,
  trait NodeSpanning,
  trait NodeStateful,
  trait StereoDelaySym,
  trait StereoFilterSym,
  trait StereoSym,
  effective_sample_count,
  exit_deliverable,
  is_finite,
  is_finite_positive,
  lin_map,
  max_feedback_amount,
  mono_shape,
  node_accepts_slot,
  optimize_graph,
  pan_left_gain,
  pan_right_gain,
  range,
  replay,
  sanitize_buffer,
  stereo_shape,
}
